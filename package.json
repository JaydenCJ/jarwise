{
  "name": "jarwise",
  "version": "0.1.0",
  "description": "Explains Set-Cookie behavior — SameSite, Secure, Domain scoping, and redirect survival — by implementing the cookie RFC as an explainable, offline simulator.",
  "author": "JaydenCJ <aisingioro.kiyon@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "jarwise": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "cookies",
    "set-cookie",
    "samesite",
    "rfc6265",
    "http",
    "security",
    "debugging",
    "cli"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/jarwise.git"
  },
  "homepage": "https://github.com/JaydenCJ/jarwise#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/jarwise/issues"
  }
}
